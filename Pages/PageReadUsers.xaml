<Page x:Class="UP_02.Pages.PageReadUsers"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP_02.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageReadUsers"
      Loaded="Page_Loaded"
      KeyDown="Page_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="White" 
                Padding="20" 
                BorderBrush="#E0E0E0" 
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" 
                        x:Name="BackButton"
                        Click="BackButton_Click"
                        Background="Transparent" 
                        BorderThickness="0"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Назад" FontSize="16" Foreground="#007ACC" Margin="5,0,0,0"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" 
                Background="White" 
                Padding="20" 
                BorderBrush="#E0E0E0" 
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" 
                        Width="60" 
                        Height="80" 
                        CornerRadius="4" 
                        Background="#E0E0E0"
                        Margin="0,0,15,0">
                    <Image x:Name="BookCoverImageSmall" 
                           Stretch="UniformToFill"/>
                </Border>

                <StackPanel Grid.Column="1" 
                            VerticalAlignment="Center">
                    <TextBlock x:Name="BookTitleText" 
                               Text="Загрузка..." 
                               FontSize="20" 
                               FontWeight="SemiBold" 
                               Foreground="#333333"
                               TextWrapping="Wrap"
                               Margin="0,0,0,5"/>
                    <TextBlock x:Name="BookAuthorText" 
                               Text="" 
                               FontSize="16" 
                               Foreground="#666666"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" x:Name="LoadingPanel" Background="#F5F5F5" Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="2" x:Name="ContentGrid" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" 
                          x:Name="ContentScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="White"
                          ScrollChanged="ContentScrollViewer_ScrollChanged">

                <Border Padding="50,30"
                        Background="White"
                        x:Name="ContentBorder">

                    <StackPanel>
                        <TextBlock x:Name="BookContentText" 
                                   Text=""
                                   FontSize="16"
                                   FontFamily="Georgia"
                                   TextWrapping="Wrap"
                                   LineHeight="28"
                                   LineStackingStrategy="MaxHeight"
                                   Foreground="#333333"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <Border Grid.Row="1" 
                    Background="White" 
                    Padding="15,10"
                    BorderBrush="#E0E0E0" 
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" 
                            x:Name="PrevPageButton"
                            Click="PrevPageButton_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            IsEnabled="False"
                            ToolTip="Предыдущая страница (←)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="←" FontSize="24" Foreground="#007ACC" VerticalAlignment="Center"/>
                            <TextBlock Text="Предыдущая" FontSize="16" Foreground="#007ACC" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <StackPanel Grid.Column="1" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="CurrentPageText" 
                                   Text="1" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="#007ACC"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text=" / " FontSize="16" Foreground="#666666" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TotalPagesText" 
                                   Text="0" 
                                   FontSize="16" 
                                   Foreground="#666666"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="2" 
                            x:Name="NextPageButton"
                            Click="NextPageButton_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            IsEnabled="False"
                            ToolTip="Следующая страница (→)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Следующая" FontSize="16" Foreground="#007ACC" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="→" FontSize="24" Foreground="#007ACC" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" 
                Background="White" 
                Padding="10"
                BorderBrush="#E0E0E0" 
                BorderThickness="0,1,0,0"
                Visibility="Collapsed"/>
    </Grid>
</Page>