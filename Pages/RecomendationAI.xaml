<Page x:Class="UP_02.Pages.RecomendationAI"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP_02.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="800"
      Title="AI Рекомендации">

    <Grid>
        <!-- Верхняя синяя панель в стиле MainPage -->
        <Rectangle Fill="#4A6FA5" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="120"/>

        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" 
                    Background="White" 
                    CornerRadius="10" 
                    Padding="15"
                    Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            x:Name="BtnBack"
                            Click="BtnBack_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,15,0" Height="50" VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Назад" FontSize="14" Foreground="#007ACC" Margin="3,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <StackPanel Grid.Column="1" Margin="0,0,0,0">
                        <TextBlock Text="AI Рекомендации" 
                                   FontSize="22" 
                                   FontWeight="Bold"
                                   Foreground="#2C3E50"/>
                        <TextBlock Text="Персональные подборки от нейросети" 
                                   FontSize="13" 
                                   Foreground="#7F8C8D"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" 
                        Background="White" 
                        CornerRadius="10" 
                        Padding="15"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Запрос" 
                                   FontSize="15" 
                                   FontWeight="SemiBold"
                                   Foreground="#2C3E50"
                                   Margin="0,0,0,10"/>

                        <TextBox x:Name="TxtSimpleQuery" 
                                 Padding="8,6" 
                                 FontSize="12"
                                 Background="#F8F9FA"
                                 BorderBrush="#E0E0E0"
                                 BorderThickness="1"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Height="60"
                                 Margin="0,0,0,12"
                                 Text="Порекомендуй книгу..."/>

                        <Button x:Name="BtnSimpleAsk" 
                                Content=" Запросить" 
                                FontSize="12"
                                Background="#3498DB"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="10,8"
                                Margin="0,0,0,15"
                                Height="35"
                                Cursor="Hand"
                                Click="BtnSimpleAsk_Click"/>

                        <Rectangle Height="1" Fill="#ECF0F1" Margin="0,12,0,12"/>

                        <TextBlock Text="Персональные" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"
                                   Foreground="#2C3E50"
                                   Margin="0,0,0,12"/>

                        <Button x:Name="BtnPersonal" 
                                Content=" Мои рекомендации" 
                                FontSize="12"
                                Background="#9B59B6"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="10,8"
                                Margin="0,0,0,15"
                                Height="35"
                                Cursor="Hand"
                                Click="BtnPersonal_Click"/>

                        <Button x:Name="BtnAuto" 
                                Content=" Авто-подбор" 
                                FontSize="12"
                                Background="#E67E22"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="10,8"
                                Margin="0,0,0,15"
                                Height="35"
                                Cursor="Hand"
                                Click="BtnAuto_Click"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" 
                        Background="White" 
                        CornerRadius="10" 
                        Padding="15">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Результат" 
                                   FontSize="15" 
                                   FontWeight="SemiBold"
                                   Foreground="#2C3E50"
                                   Margin="0,0,0,10"/>

                        <StackPanel x:Name="PnlLoading" 
                                    Grid.Row="1" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Center"
                                    Visibility="Collapsed">
                            <ProgressBar IsIndeterminate="True" 
                                         Width="150" 
                                         Height="3"
                                         Foreground="#3498DB"/>
                            <TextBlock Text="Нейросеть думает..." 
                                       FontSize="12" 
                                       Foreground="#7F8C8D"
                                       Margin="0,8,0,0"/>
                        </StackPanel>

                        <Border x:Name="PnlError" 
                                Grid.Row="1" 
                                Background="#FDEDEC" 
                                BorderBrush="#E74C3C" 
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="❌ Ошибка" 
                                           FontWeight="SemiBold" 
                                           Foreground="#C0392B"
                                           FontSize="13"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtError" 
                                           Foreground="#7F8C8D"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" 
                                      x:Name="ScrollResult"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <TextBlock x:Name="TxtResult" 
                                       Foreground="#2C3E50" 
                                       FontSize="13"
                                       LineHeight="18"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>

                        <StackPanel Grid.Row="2" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Right"
                                    Margin="0,12,0,0"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="1" 
                VerticalAlignment="Bottom" 
                Background="#F8F9FA" 
                CornerRadius="8" 
                Padding="10,6"
                Margin="15,0,15,10">
        </Border>
    </Grid>
</Page>