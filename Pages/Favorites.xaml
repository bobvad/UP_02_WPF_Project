<Page x:Class="UP_02.Pages.Favorites"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP_02.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Favorites"
      Background="White">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Стиль для карточки книги -->
        <Style x:Key="BookCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,20,20"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="320"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#33000000" Direction="315" ShadowDepth="2" BlurRadius="5" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" 
                Background="White" 
                Padding="20" 
                BorderBrush="#E0E0E0" 
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Кнопка назад -->
                <Button Grid.Column="0" 
                        x:Name="BackButton"
                        Click="BackButton_Click"
                        Background="Transparent" 
                        BorderThickness="0"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Назад" FontSize="16" Foreground="#007ACC"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="30,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Избранное" 
                                   FontSize="20" 
                                   FontWeight="SemiBold" 
                                   Foreground="#333333"/>
                        <TextBlock x:Name="FavoritesCountText" 
                                   Text="0 книг"
                                   FontSize="14" 
                                   Foreground="#666666"/>
                    </StackPanel>
                </StackPanel>

                <!-- Поиск -->
                <Border Grid.Column="2" 
                        Background="#F5F5F5" 
                        CornerRadius="4" 
                        Height="36" 
                        Width="250"
                        Margin="0,0,10,0"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="1" 
                                 x:Name="SearchTextBox"
                                 Background="Transparent" 
                                 BorderThickness="0" 
                                 Foreground="#333333" 
                                 VerticalAlignment="Center"
                                 Padding="5,0,5,0"
                                 FontSize="14"
                                 TextChanged="SearchTextBox_TextChanged"/>
                    </Grid>
                </Border>

                <Button Grid.Column="3"
                        Content="Каталог"
                        Background="#007ACC"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="15,8"
                        Cursor="Hand"
                        Height="36"
                        Click="GoToCatalog_Click"
                        FontWeight="SemiBold"
                        FontSize="14"/>
            </Grid>
        </Border>

        <!-- Основная область с книгами -->
        <Grid Grid.Row="1" Background="#F5F5F5">
            <ScrollViewer VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#F5F5F5"
                          Padding="20">

                <ItemsControl x:Name="FavoritesList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Карточка книги -->
                            <Border Style="{StaticResource BookCardStyle}"
                                    Tag="{Binding .}"
                                    MouseEnter="BookBorder_MouseEnter"
                                    MouseLeave="BookBorder_MouseLeave">
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Дата добавления -->
                                    <TextBlock Grid.Row="0" 
                                               Text="{Binding AddedDate, StringFormat='Добавлено: {0}'}" 
                                               FontSize="10" 
                                               Foreground="#999999"
                                               Margin="0,0,0,5"
                                               HorizontalAlignment="Center"/>

                                    <!-- Обложка книги -->
                                    <Border Grid.Row="1" 
                                            Background="#F9F9F9" 
                                            CornerRadius="4"
                                            Height="150"
                                            Margin="0,0,0,10">
                                        <Grid>
                                            <!-- Заглушка для обложки -->
                                            <TextBlock Text="📚" 
                                                       FontSize="48" 
                                                       Foreground="#CCCCCC" 
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>

                                            <!-- Здесь будет реальное изображение, когда добавится -->
                                            <!--
                                            <Image Source="{Binding ImageUrl}" 
                                                   Stretch="Uniform" 
                                                   MaxHeight="150"/>
                                            -->
                                        </Grid>
                                    </Border>

                                    <!-- Название книги -->
                                    <TextBlock Grid.Row="2" 
                                               Text="{Binding Title}" 
                                               FontWeight="SemiBold" 
                                               Foreground="#333333"
                                               FontSize="14"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               MaxHeight="40"
                                               Margin="0,0,0,5"/>

                                    <!-- Автор -->
                                    <TextBlock Grid.Row="3" 
                                               Text="{Binding Author}" 
                                               Foreground="#666666"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               MaxHeight="40"
                                               Margin="0,0,0,10"/>

                                    <!-- Кнопка удаления -->
                                    <Button Grid.Row="4" 
                                            Content="✖ Удалить"
                                            Tag="{Binding Id}"
                                            Click="RemoveFromFavorites_Click"
                                            Background="#FF4444"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Padding="10,5"
                                            Cursor="Hand"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Height="28"
                                            Margin="0,5,0,0">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="4"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Пустое состояние -->
        <Border Grid.Row="1" 
                x:Name="EmptyStatePanel" 
                Background="White" 
                CornerRadius="8" 
                Padding="30"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect Color="#33000000" Direction="315" ShadowDepth="2" BlurRadius="5" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="📚" 
                           FontSize="64" 
                           Foreground="#CCCCCC" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="В избранном пока пусто" 
                           FontSize="20" 
                           FontWeight="SemiBold"
                           Foreground="#333333" 
                           Margin="0,20,0,10" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Добавляйте понравившиеся книги в избранное" 
                           FontSize="14" 
                           Foreground="#666666" 
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"/>
                <Button Content="Перейти в каталог"
                        Background="#007ACC"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="20,10"
                        Margin="0,20,0,0"
                        Cursor="Hand"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Click="GoToCatalog_Click"
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>