<Page x:Class="UP_02.Pages.Favorites"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:UP_02.Pages"
      xmlns:carts="clr-namespace:UP_02.Pages.Carts"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Favorites"
      Background="White">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="White" 
                Padding="20" 
                BorderBrush="#E0E0E0" 
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" 
                        x:Name="BackButton"
                        Click="BackButton_Click"
                        Background="Transparent" 
                        BorderThickness="0"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Назад" FontSize="16" Foreground="#007ACC" Margin="5,0,0,0"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="30,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Избранное" 
                                   FontSize="20" 
                                   FontWeight="SemiBold" 
                                   Foreground="#333333"/>
                        <TextBlock Text="Ваши сохраненные книги" 
                                   FontSize="14" 
                                   Foreground="#666666"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="2" 
                        Background="#F5F5F5" 
                        CornerRadius="4" 
                        Height="36" 
                        Width="250"
                        Margin="0,0,10,0"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"  
                                   Foreground="#999999" 
                                   VerticalAlignment="Center" 
                                   Margin="8,0,0,0"/>

                        <TextBox Grid.Column="1" 
                                 x:Name="SearchTextBox"
                                 Background="Transparent" 
                                 BorderThickness="0" 
                                 Foreground="#333333" 
                                 VerticalAlignment="Center"
                                 Padding="5,0,0,0"
                                 FontSize="14"
                                 TextChanged="SearchTextBox_TextChanged"/>
                    </Grid>
                </Border>

                <Button Grid.Column="3"
                        Content="Каталог"
                        Background="#007ACC"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="15,8"
                        Cursor="Hand"
                        Height="36"
                        Click="GoToCatalog_Click"
                        FontWeight="SemiBold"
                        FontSize="14"/>

                <TextBlock x:Name="FavoritesCountText" 
                           Visibility="Collapsed"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Background="#F5F5F5">
            <ScrollViewer VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#F5F5F5"
                          Padding="20">

                <ItemsControl x:Name="FavoritesList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="1" 
                x:Name="EmptyStatePanel" 
                Background="White" 
                CornerRadius="8" 
                Padding="30"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Collapsed">

            <Border.Effect>
                <DropShadowEffect Color="#33000000" Direction="315" ShadowDepth="2" BlurRadius="5" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock 
                           FontSize="64" 
                           Foreground="#CCCCCC" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="В избранном пока пусто" 
                           FontSize="20" 
                           FontWeight="SemiBold"
                           Foreground="#333333" 
                           Margin="0,20,0,10" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Добавляйте понравившиеся книги в избранное" 
                           FontSize="14" 
                           Foreground="#666666" 
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"/>
                <Button Content="Перейти в каталог"
                        Background="#007ACC"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="20,10"
                        Margin="0,20,0,0"
                        Cursor="Hand"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Click="GoToCatalog_Click"
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>